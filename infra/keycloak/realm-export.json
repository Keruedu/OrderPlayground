{
  "realm": "order-playground",
  "enabled": true,
  "displayName": "Order Playground",
  "registrationAllowed": false,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "user"
      },
      {
        "name": "admin"
      }
    ]
  },
  "clients": [
    {
      "clientId": "gateway-api",
      "name": "gateway-api",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "defaultClientScopes": [
        "profile",
        "roles",
        "email",
        "web-origins"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "gateway-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "user1",
      "enabled": true,
      "emailVerified": true,
      "email": "user1@example.com",
      "firstName": "Demo",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "user1pass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "admin1",
      "enabled": true,
      "emailVerified": true,
      "email": "admin1@example.com",
      "firstName": "Demo",
      "lastName": "Admin",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "admin1pass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "admin"
      ]
    }
  ]
}
